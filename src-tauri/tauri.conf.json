{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "2D MMO Launcher",
  "version": "0.1.0",
  "identifier": "dev.kaiquelb.2d-mmo-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "2D MMO Launcher",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [
      "manifests/*.json"
    ]
  }
}
